// prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Employee {
  id              String   @id @default(cuid())
  name            String   // "First Last"
  rampName        String   // "Last, First" (RAMP display format)
  email           String
  companyGroup    String   // Linea Solutions | Linea Solutions ULC | Linea Secure | ICON
  businessUnit    String   // Delivery | Cyber | Data
  careerPath      String   // Consultant | Specialist
  roleFamily      String   // BA | PM | TechAnalysis | Testing | Training | OCM | TechWriting | Data | Cyber
  practice        String   // Pension | Insurance | WorkersComp | Benefits | CrossPractice
  level           String   // Associate | Consultant | Senior | Principal
  title           String   // Full title e.g. "Senior Consultant"
  location        String   // US | Canada
  resumeText      String   // Synthetic resume
  extractedSkills String   // JSON as string
  pageLayout      String   @default("{}")  // JSON: { tagline, insight, emphasis, accentColor, sectionOrder, statusBanner, keyStats }
  reportsTo       String?  // Employee.id of direct manager (self-referential)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  allocations     Allocation[]
  manager         Employee?  @relation("ReportsTo", fields: [reportsTo], references: [id])
  reports         Employee[] @relation("ReportsTo")
}

model Project {
  id                  String    @id @default(cuid())
  rampProjectCode     String    // "PRJ-000456"
  name                String    // Display name e.g. "Yukon - SOW #4 - Pre Implementation"
  clientId            String
  clientName          String
  accountExecutive    String    // RAMP name format "Last, First"
  engagementManager   String    // RAMP name format "Last, First"
  engagementClass     String    // Client | ULC | Cyber | ICON
  industryTag         String?   // pension | insurance | workers_comp | benefits | cybersecurity | data
  scopeCategories     String?   // JSON array as string: assessment, roadmap, implementation, data_conversion, cybersecurity, ocm
  status              String    @default("In Progress")  // Planning | In Progress | On Hold | Closing | Completed
  description         String    @default("")             // Project overview paragraph(s)
  startDate           DateTime?
  endDate             DateTime?
  currentPhase        String    @default("")             // Discovery | Assessment | Planning | Requirements | Implementation | Testing | UAT | Go-Live | Support
  milestones          String    @default("[]")           // JSON array of {title, date, status, notes}
  pageLayout          String    @default("{}")           // JSON: { tagline, insight, statusBanner, highlights, keyStats }
  createdAt           DateTime  @default(now())

  allocations         Allocation[]
}

model Allocation {
  id                String   @id @default(cuid())
  assignmentCode    String   // "AS-03624"
  assignmentDetail  String   // "Last, First-Project Name (MM/DD/YY-MM/DD/YY)"
  employeeId        String
  projectId         String
  roleOnProject     String   // PM | BA | DataAnalyst | OCM | AIAdvisory | Cyber | Testing | Oversight
  startDate         DateTime
  endDate           DateTime
  allocationPercent Int      // 0-100
  createdAt         DateTime @default(now())

  employee          Employee @relation(fields: [employeeId], references: [id])
  project           Project  @relation(fields: [projectId], references: [id])

  @@index([employeeId])
  @@index([projectId])
  @@index([startDate])
}

model ClientNote {
  id         String   @id @default(cuid())
  clientId   String   @unique
  clientName String
  pageLayout String   @default("{}")  // JSON: same structure as Employee/Project pageLayout
  notes      String   @default("")
  updatedAt  DateTime @updatedAt
}

model ChangeLog {
  id          String    @id @default(cuid())
  command     String                         // original NL command text
  actionPlan  String                         // JSON: structured actions Claude planned
  executed    Boolean   @default(false)
  executedAt  DateTime?
  docText     String    @default("")         // extracted text from uploaded document
  docFileName String    @default("")         // original filename of uploaded doc
  summary     String    @default("")         // LLM-generated summary of what changed
  createdAt   DateTime  @default(now())

  @@index([createdAt])
}

model FeedbackTicket {
  id                   String   @id @default(cuid())
  type                 String   // bug, feature, data_issue, question, action
  status               String   @default("new")
  title                String
  rawText              String
  chatTranscript       String
  structuredJson       String   // JSON as string
  pageContext          String?
  createdBy            String?
  // Action engine fields
  complexity           String   @default("large")  // "small" | "large"
  autoApproved         Boolean  @default(false)
  implementationPlan   String   @default("")        // JSON steps array
  implementationResult String   @default("")        // JSON: { success, changes, summary }
  notifyEmail          String   @default("")        // email to notify on completion
  errorMessage         String   @default("")
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@index([status])
  @@index([createdAt])
  @@index([complexity])
}
